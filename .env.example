# ── 3D Earth Lab — environment variables ──────────────────────────────
# Copy this file to ".env" and fill in the values. The ".env" file is
# gitignored. All keys are public, browser-side keys — restrict them by
# domain in each provider's dashboard before deploying publicly.

# Cesium ion access token (free): https://ion.cesium.com/tokens
# Required by the CesiumJS prototype to load Cesium World Bathymetry.
# Without it, the Cesium page falls back to a flat globe + OpenStreetMap imagery.
VITE_CESIUM_ION_TOKEN=

# MapTiler API key (free): https://cloud.maptiler.com/account/keys/
# Optional. Improves the MapLibre prototype's basemap + terrain.
# Without it, MapLibre falls back to keyless ESRI imagery + AWS terrain tiles.
VITE_MAPTILER_KEY=
